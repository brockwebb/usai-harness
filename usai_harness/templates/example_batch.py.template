"""Example batch job using the USAi Harness.

Reads inputs/sample_inputs.txt (one prompt per line), sends each as a task,
writes outputs/sample_outputs.jsonl with the response per task.

This file is generated by `usai-harness project-init`. Edit it freely or
replace it with the real job for your project.
"""

import asyncio
import json
from pathlib import Path

from usai_harness import USAiClient


PROJECT_ROOT = Path(__file__).resolve().parent.parent
INPUT_FILE = PROJECT_ROOT / "inputs" / "sample_inputs.txt"
OUTPUT_FILE = PROJECT_ROOT / "outputs" / "sample_outputs.jsonl"


async def main() -> None:
    OUTPUT_FILE.parent.mkdir(parents=True, exist_ok=True)
    INPUT_FILE.parent.mkdir(parents=True, exist_ok=True)

    if not INPUT_FILE.exists():
        INPUT_FILE.write_text(
            "Summarize in one sentence: the harness is a rate-limited LLM client.\n"
            "List three colors.\n",
            encoding="utf-8",
        )

    prompts = [
        line.strip()
        for line in INPUT_FILE.read_text(encoding="utf-8").splitlines()
        if line.strip()
    ]
    tasks = [
        {
            "messages": [{"role": "user", "content": p}],
            "task_id": f"example_{i:03d}",
        }
        for i, p in enumerate(prompts)
    ]

    async with USAiClient(project="example") as client:
        results = await client.batch(tasks, job_name="example_batch")

    with OUTPUT_FILE.open("w", encoding="utf-8") as f:
        for r in results:
            f.write(json.dumps({
                "task_id": r.task_id,
                "success": r.success,
                "status_code": r.status_code,
                "latency_ms": r.latency_ms,
                "response": r.response,
            }, default=str) + "\n")

    print(f"Wrote {len(results)} results to {OUTPUT_FILE}")


if __name__ == "__main__":
    asyncio.run(main())
