# .env.example — project-local credential override
#
# This file is a TEMPLATE. Copy to .env in the project root to override
# user-level credentials for this project only.
#
# Per ADR-008, the default credential location is the user-level directory:
#   Linux/macOS:  ~/.config/usai-harness/.env
#   Windows:      %APPDATA%\usai-harness\.env
#
# Set up the user-level config with:  usai-harness init
#
# Resolution order (first match wins):
#   1. ./.env            (this file, when copied in)
#   2. user-level .env
#   3. OS environment variables
#
# Values below are examples. Do not commit your real .env — it is gitignored.

USAI_API_KEY=your-api-key-here
USAI_BASE_URL=https://your-agency-endpoint.usai.gov/api/v1

# Optional: additional providers
# OPENROUTER_API_KEY=

# Note for Azure Key Vault users:
# This .env is for env-based credential resolution. If you select the
# `azure_keyvault` credentials backend in your project config, the relevant
# field in configs/models.yaml is `api_key_secret` (a Key Vault secret
# name), not `api_key_env`. The old `api_key_env` for Azure backends is
# accepted with a DeprecationWarning in 0.1.x and removed in 0.2.0.
